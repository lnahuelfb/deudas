    "@types/node": "^24.10.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "prisma": "6.19.2",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
